// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // 2FA — quando true, login exige TOTP code.
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  twoFactorBackupCodes String[] // hashes dos backup codes (single-use)

  // Email verification
  emailVerified    Boolean   @default(false)
  emailVerifiedAt  DateTime?

  wallets      Wallet[]
  transactions Transaction[]
  categories   Category[] @relation("UserCategories")
  budgets      Budget[]
  goals        Goal[]
  bills        RecurringBill[]

  // Shared access — accounts THIS user shares with others
  sharedOut    SharedAccess[] @relation("SharedOut")
  // Shared access — accounts shared WITH this user by others
  sharedIn     SharedAccess[] @relation("SharedIn")

  // Auth sessions (refresh tokens) e audit log
  sessions     Session[]
  auditLogs    AuditLog[]
  verificationTokens VerificationToken[]
}

enum VerificationTokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
}

/// Tokens single-use para verificação de email e reset de senha.
/// Armazenamos só o SHA-256 do token; o texto original vai por email.
model VerificationToken {
  id        Int                   @id @default(autoincrement())
  userId    Int
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String                @unique
  type      VerificationTokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime              @default(now())

  @@index([userId, type])
  @@index([expiresAt])
}

/// Sessão refresh-token. O `tokenHash` é SHA-256 do refresh token.
/// O access-token (JWT curto) não é armazenado.
model Session {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String   @unique
  userAgent    String?
  ipAddress    String?
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?

  @@index([userId])
  @@index([expiresAt])
}

/// Log de ações sensíveis: login, logout, mudança de senha, compartilhamento, etc.
model AuditLog {
  id           Int      @id @default(autoincrement())
  userId       Int?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action       String   // ex: "auth.login", "auth.logout", "user.password_change", "share.invite"
  resourceType String?  // ex: "user", "wallet", "share"
  resourceId   String?  // ex: "42"
  ipAddress    String?
  userAgent    String?
  metadata     Json?    // payload livre (e.g. email convidado, motivo)
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

enum SharePermission {
  READ
  WRITE
}

enum ShareStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model SharedAccess {
  id               Int             @id @default(autoincrement())
  ownerId          Int
  owner            User            @relation("SharedOut", fields: [ownerId], references: [id], onDelete: Cascade)
  sharedWithUserId Int
  sharedWithUser   User            @relation("SharedIn", fields: [sharedWithUserId], references: [id], onDelete: Cascade)
  permission       SharePermission @default(READ)
  status           ShareStatus     @default(PENDING)
  createdAt        DateTime        @default(now())
  acceptedAt       DateTime?

  @@unique([ownerId, sharedWithUserId])
  @@index([sharedWithUserId])
}

enum WalletType {
  CHECKING
  CREDIT
  INVESTMENT
  OTHER
}

model Wallet {
  id        Int        @id @default(autoincrement())
  name      String
  balance   Decimal    @default(0)
  type      WalletType @default(CHECKING)
  userId    Int
  user      User       @relation(fields: [userId], references: [id])
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  transactions Transaction[]
  bills        RecurringBill[]

  @@index([userId])
}

enum TxType {
  INCOME
  EXPENSE
  TRANSFER
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String
  icon      String?
  userId    Int?
  user      User?      @relation("UserCategories", fields: [userId], references: [id])
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  transactions Transaction[]
  budgets      Budget[]
  bills        RecurringBill[]

  @@unique([userId, name])
}

model Transaction {
  id              Int       @id @default(autoincrement())
  type            TxType
  amount          Decimal
  occurredAt      DateTime
  description     String?
  transferGroupId String?
  userId          Int
  user            User      @relation(fields: [userId], references: [id])

  categoryId  Int?
  category    Category? @relation(fields: [categoryId], references: [id])

  walletId    Int
  wallet      Wallet    @relation(fields: [walletId], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, occurredAt])
  @@index([categoryId])
  @@index([walletId])
}

model Budget {
  id         Int      @id @default(autoincrement())
  month      Int      // 1..12
  year       Int
  limit      Decimal
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, categoryId, month, year])
}

model Goal {
  id            Int       @id @default(autoincrement())
  userId        Int
  name          String
  emoji         String    @default("🎯")
  targetAmount  Decimal   @db.Decimal(12, 2)
  currentAmount Decimal   @default(0) @db.Decimal(12, 2)
  deadline      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RecurringBill {
  id         Int      @id @default(autoincrement())
  userId     Int
  name       String
  amount     Decimal  @db.Decimal(12, 2)
  dueDay     Int
  categoryId Int?
  walletId   Int?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  wallet   Wallet?   @relation(fields: [walletId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, dueDay])
}
